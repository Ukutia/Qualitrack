# ─────────────────────────────────────────────────────────────
# Qualitrack — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=qualitrack
POSTGRES_PASSWORD=qualitrack
POSTGRES_DB=qualitrack

# Conexión que usa Prisma (host "db" = nombre del servicio en docker-compose)
DATABASE_URL=postgresql://qualitrack:qualitrack@db:5432/qualitrack?schema=public

# Backend
PORT=4000
NODE_ENV=development
JWT_SECRET=cambia-este-secreto-en-produccion
MAX_FILE_SIZE_MB=10
# Puerto del host para el frontend (cámbielo si 5173 está ocupado).
FRONTEND_PORT=5173
# URL del frontend (para CORS y redirección del callback de Google).
# Debe coincidir con FRONTEND_PORT.
FRONTEND_URL=http://localhost:5173

# Admin pre-cargado (seed)
ADMIN_EMAIL=admin@qualitrack.cl
ADMIN_PASSWORD=admin123
ADMIN_NAME=Encargado de Aseguramiento de Calidad

# Google Gemini — OPCIONAL para clasificación con IA.
# Obtén tu API key gratis en https://aistudio.google.com/app/apikey
# Si se deja vacía, el sistema usa clasificación por keywords (modo offline).
GEMINI_API_KEY=

# Google Drive (HU09) — OPCIONAL.
# Si se dejan vacías, la app funciona igual y la pantalla de nube muestra
# instrucciones de configuración.
# Crear credenciales OAuth en https://console.cloud.google.com/apis/credentials
# Tipo: "ID de cliente de OAuth" -> "Aplicación web".
# Redirect URI autorizado: http://localhost:4000/api/cloud/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/cloud/google/callback

# Frontend (Vite). En docker-compose el proxy /api ya apunta al backend,
# por lo que normalmente no hace falta tocar esto.
VITE_API_URL=/api
